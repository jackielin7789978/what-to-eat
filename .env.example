# Copy this file to .env for local development via `netlify dev`
# Netlify Functions read .env (not .env.local — that's Vite-only)
# NEVER commit .env to the repository

# Google Maps Platform API key
# Restrict this key in Google Cloud Console:
#   - HTTP referrers: your Netlify domain + localhost for dev
#   - APIs: Places API (New), Routes API
GOOGLE_MAPS_API_KEY=your_api_key_here
